# Copy to .env and fill real values. NEVER commit .env or paste its values into
# issues/logs. Only .env.example (this file, no secrets) belongs in Git.

# --- Database URLs ----------------------------------------------------------
# DATABASE_URL uses the non-superuser application role (second_brain_app).
# SCHEMA_DATABASE_URL uses the owner role (second_brain); used only for
# init-db / reset-db / create-*-invite. The two MUST differ.
#
# Local development (compose postgres on 127.0.0.1:55432):
DATABASE_URL=postgresql+asyncpg://second_brain_app@127.0.0.1:55432/second_brain
SCHEMA_DATABASE_URL=postgresql+asyncpg://second_brain@127.0.0.1:55432/second_brain
#
# Server (compose bridge network): host = postgres, port = 5432 (not published
# outside). On the VPS, .env uses these instead of the localhost URLs above:
# DATABASE_URL=postgresql+asyncpg://second_brain_app@postgres:5432/second_brain
# SCHEMA_DATABASE_URL=postgresql+asyncpg://second_brain@postgres:5432/second_brain

# Test databases (used by pytest/conftest and CI only; NOT read by the runtime).
# Must differ from DATABASE_URL / SCHEMA_DATABASE_URL above.
TEST_DATABASE_URL=postgresql+asyncpg://second_brain_app@127.0.0.1:55432/second_brain_test
TEST_SCHEMA_DATABASE_URL=postgresql+asyncpg://second_brain@127.0.0.1:55432/second_brain_test

# --- Telegram / invite secrets ----------------------------------------------
TELEGRAM_BOT_TOKEN=
INVITE_TOKEN_PEPPER=
INVITE_TOKEN_PEPPER_KEY_ID=

# --- Telegram webhook + INBOX (эпик API-1, B1) --------------------------------
# Секрет заголовка X-Telegram-Bot-Api-Secret-Token (тот же, что передаётся в
# setWebhook при cutover B3). ПУСТО = webhook выключен: роут отвечает 503,
# рабочая дверь — long-polling. Секрет живёт ТОЛЬКО в заголовке, не в URL.
# TELEGRAM_WEBHOOK_SECRET=
# Cap тела запроса webhook-роута, байты (больше → 413).
# WEBHOOK_MAX_BODY_BYTES=1048576
# Бюджет попыток inbox-шага воркера: после стольких сбоев строка — failed
# (failed-голова НЕ блокирует хвост очереди).
# INBOX_MAX_ATTEMPTS=5
# Линейный бэкофф между попытками: attempt_count × столько секунд. Пока
# головная строка ждёт бэкофф, хвост не обрабатывается (строгий порядок).
# INBOX_RETRY_BACKOFF_SECONDS=30

# --- Авто-панель (досылка панели с кнопками) ---------------------------------
# Через сколько секунд после КАЖДОГО действия пользователя (текст, голос,
# кнопка) бот досылает панель с кнопками, чтобы она всегда была внизу чата.
# Несколько действий подряд = одна панель после последнего. 0 = выключено.
# PANEL_FOLLOWUP_SECONDS=5

# --- Title страниц (S1: ссылки при захвате) ----------------------------------
# Фоновый воркер подтягивает <title> страниц для сохранённых ссылок.
# Выключатель шага (on/off). off → pending-строки просто ждут.
# TITLE_FETCH_ENABLED=on
# Таймаут одного HTTP-запроса, секунды.
# TITLE_FETCH_TIMEOUT_SECONDS=5
# Cap на тело ответа (и сжатое, и распакованное), байты.
# TITLE_FETCH_MAX_BYTES=262144
# Потолок редиректов (каждый hop проходит SSRF-проверку заново).
# TITLE_FETCH_MAX_REDIRECTS=3
# Максимальная длина сохранённого title, символы.
# TITLE_MAX_LENGTH=200
# Бюджет попыток: после стольких сбоев строка становится failed навсегда.
# TITLE_FETCH_MAX_ATTEMPTS=5
# Линейный бэкофф между попытками: attempt_count × столько секунд.
# TITLE_FETCH_RETRY_BACKOFF_SECONDS=60

# --- OpenRouter (classification / memory reasoning) -------------------------
# The only place the OpenRouter key is stored; read from here, never hardcoded
# or logged.
OPEN_ROUTER_AI_KEY=

# --- Voice storage ----------------------------------------------------------
# Local default is .data/voice. On the server, point it inside the ./data
# volume so audio persists across redeploys:
VOICE_STORAGE_ROOT=.data/voice
# Server default:
# VOICE_STORAGE_ROOT=/app/data/voice

# --- Image storage (S2: фото) ------------------------------------------------
# Оригиналы фото (immutable, {space}/{capture}/original.<ext>). Локальный
# дефолт .data/images; на сервере — внутрь ./data-тома, как у голоса:
# IMAGE_STORAGE_ROOT=.data/images
# IMAGE_STORAGE_ROOT=/app/data/images
# Потолок размера скачиваемого фото, байты (больше → мягкий отказ шага).
# IMAGE_MAX_FILE_SIZE_BYTES=10485760

# Optional: override the Whisper model. Voice transcription now works on Linux
# too (faster-whisper is cross-platform). Default is "small"; the first
# transcription downloads and caches the model weights once.
# WHISPER_MODEL=small

# --- HuggingFace / sentence-transformers weight cache -----------------------
# Not read by settings.py, but read by the libraries. On the server these point
# into the ./data volume so E5 weights download once and persist:
# HF_HOME=/app/data/hf-cache
# SENTENCE_TRANSFORMERS_HOME=/app/data/hf-cache
