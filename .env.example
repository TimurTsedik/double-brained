# Copy to .env and fill real values. NEVER commit .env or paste its values into
# issues/logs. Only .env.example (this file, no secrets) belongs in Git.

# --- Database URLs ----------------------------------------------------------
# DATABASE_URL uses the non-superuser application role (second_brain_app).
# SCHEMA_DATABASE_URL uses the owner role (second_brain); used only for
# init-db / reset-db / create-*-invite. The two MUST differ.
#
# Local development (compose postgres on 127.0.0.1:55432):
DATABASE_URL=postgresql+asyncpg://second_brain_app@127.0.0.1:55432/second_brain
SCHEMA_DATABASE_URL=postgresql+asyncpg://second_brain@127.0.0.1:55432/second_brain
#
# Server (compose bridge network): host = postgres, port = 5432 (not published
# outside). On the VPS, .env uses these instead of the localhost URLs above:
# DATABASE_URL=postgresql+asyncpg://second_brain_app@postgres:5432/second_brain
# SCHEMA_DATABASE_URL=postgresql+asyncpg://second_brain@postgres:5432/second_brain

# Test databases (used by pytest/conftest and CI only; NOT read by the runtime).
# Must differ from DATABASE_URL / SCHEMA_DATABASE_URL above.
TEST_DATABASE_URL=postgresql+asyncpg://second_brain_app@127.0.0.1:55432/second_brain_test
TEST_SCHEMA_DATABASE_URL=postgresql+asyncpg://second_brain@127.0.0.1:55432/second_brain_test

# --- Telegram / invite secrets ----------------------------------------------
TELEGRAM_BOT_TOKEN=
INVITE_TOKEN_PEPPER=
INVITE_TOKEN_PEPPER_KEY_ID=

# --- Токены доступа к API (эпик API-1, секция C) ------------------------------
# Перец и его идентификатор для токенов, которые пользователь выдаёт себе
# кнопкой «🔑 API». ОБЕ переменные обязательны — без них приложение не стартует.
# Перец ОТДЕЛЬНЫЙ от INVITE_TOKEN_PEPPER намеренно: ротация перца приглашений не
# должна разлогинивать все выданные API-токены (разные жизненные циклы). Смена
# API_TOKEN_PEPPER вместе с API_TOKEN_PEPPER_KEY_ID разом гасит все выданные
# токены, не трогая вход по приглашению.
API_TOKEN_PEPPER=
API_TOKEN_PEPPER_KEY_ID=
# Как часто обновлять у токена отметку «последний раз использован», секунды.
# Писать её на КАЖДЫЙ запрос API — значит превращать каждое чтение в запись в
# базу; для ответа «когда токеном пользовались» хватает и такой точности.
# 0 = писать на каждый запрос.
# API_TOKEN_LAST_USED_THROTTLE_SECONDS=300

# --- Роутер /v1 (эпик API-1, C1) ---------------------------------------------
# Лимит на ПРОВАЛЫ авторизации с одного адреса — против подбора токена. Считаются
# только провалы, поэтому обычной работе порог не мешает; исчерпан → 429, пока
# окно не сдвинется. 0 = лимит выключен. Это второй рубеж: общий лимит частоты на
# traefik стоит раньше, но он не знает, чем кончилась проверка токена.
# API_AUTH_FAILURE_LIMIT=20
# API_AUTH_FAILURE_WINDOW_SECONDS=300
# Из какого заголовка брать адрес клиента для лимита выше. ПУСТО (по умолчанию) =
# заголовкам не верим и берём адрес сокета — но на проде uvicorn запущен БЕЗ
# --proxy-headers, а traefik ходит из host-сети, поэтому в сокете лежит адрес
# docker-шлюза, ОДИН И ТОТ ЖЕ для всех: лимит на адрес вырождается в общий на
# всех. Чтобы он стал честно поадресным, поставьте здесь X-Forwarded-For —
# берётся ПРАВАЯ запись заголовка (её дописал ближайший прокси, увидев реальный
# сокет; всё левее прислал сам клиент и подделывается свободно). Включать МОЖНО
# только там, где до приложения не достучаться мимо прокси: у сервиса api нет
# секции ports, снаружи в него ходит только traefik. Если приложение доступно
# напрямую — оставьте пусто, иначе клиент назначит себе адрес сам.
# API_CLIENT_IP_HEADER=X-Forwarded-For

# --- Telegram webhook + INBOX (эпик API-1, B1) --------------------------------
# Секрет заголовка X-Telegram-Bot-Api-Secret-Token (тот же, что передаётся в
# setWebhook). На проде ЗАПОЛНЕН: webhook — рабочая дверь бота. ПУСТО = webhook
# выключен, роут отвечает 503. Секрет живёт ТОЛЬКО в заголовке, не в URL.
# ВАЖНО: роут запоминает «webhook не сконфигурирован» на весь процесс, поэтому
# после правки этой переменной ОБЯЗАТЕЛЕН рестарт контейнера api — иначе
# setWebhook будет смотреть в дверь, которая всё ещё отвечает 503.
# TELEGRAM_WEBHOOK_SECRET=
# Cap тела запроса webhook-роута, байты (больше → 413).
# WEBHOOK_MAX_BODY_BYTES=1048576
# Бюджет попыток inbox-шага воркера: после стольких сбоев строка — failed
# (failed-голова НЕ блокирует хвост очереди).
# INBOX_MAX_ATTEMPTS=5
# Линейный бэкофф между попытками: attempt_count × столько секунд. Пока
# головная строка ждёт бэкофф, хвост не обрабатывается (строгий порядок).
# INBOX_RETRY_BACKOFF_SECONDS=30

# --- Видимость очереди: second-brain-inbox-status (эпик API-1, B4) -----------
# Команда runbook'а: показывает pending/failed, возраст головы и мнение самого
# Telegram (getWebhookInfo) о доставке. Пороги ниже решают, когда команда
# вернёт ненулевой код (её можно воткнуть во внешний планировщик).
# Возраст головы очереди, с которого она считается вставшей, секунды. Порядок
# строгий: застрявшая голова держит весь хвост, поэтому секунды — норма, а
# минуты — сигнал.
# INBOX_HEAD_AGE_ALERT_SECONDS=300
# Насколько свежей должна быть жалоба Telegram (last_error_date), чтобы считать
# её аварией, а не историей, секунды. Сам Telegram это поле после удачной
# доставки НЕ сбрасывает (только setWebhook), иначе одна давняя ошибка держала
# бы команду вечно красной.
# INBOX_WEBHOOK_ERROR_WINDOW_SECONDS=3600

# --- HTTP-сервис api (эпик API-1, B2) ----------------------------------------
# Читается ТОЛЬКО docker-compose.prod.yml (подстановка), не кодом приложения.
# Порт, на котором uvicorn слушает ВНУТРИ контейнера: наружу он не публикуется
# (`ports:` нет), снаружи в сервис ходит только общий traefik сервера. Меняется
# в одном месте — команда, healthcheck и traefik-лейбл берут это же значение.
# API_PORT=8000

# --- Откат на polling (эпик API-1, B3) ---------------------------------------
# Читается ТОЛЬКО человеком/скриптом отката, не кодом приложения и не compose.
# Образ, на котором поднимать сервис polling при откате с webhook: последняя
# сборка, где опрос заведомо работал. Сервис polling живёт в профиле `rollback`
# и обычным `up -d` не поднимается; при откате оператор делает
# `export APP_IMAGE="$APP_IMAGE_POLLING_FALLBACK"` и поднимает его вручную.
# Полная процедура — раздел "Rolling back to polling" в README.md.
# APP_IMAGE_POLLING_FALLBACK=ghcr.io/timurtsedik/double-brained:sha-xxxxxxx

# --- Авто-панель (досылка панели с кнопками) ---------------------------------
# Через сколько секунд после КАЖДОГО действия пользователя (текст, голос,
# кнопка) бот досылает панель с кнопками, чтобы она всегда была внизу чата.
# Несколько действий подряд = одна панель после последнего. 0 = выключено.
# PANEL_FOLLOWUP_SECONDS=5

# --- Title страниц (S1: ссылки при захвате) ----------------------------------
# Фоновый воркер подтягивает <title> страниц для сохранённых ссылок.
# Выключатель шага (on/off). off → pending-строки просто ждут.
# TITLE_FETCH_ENABLED=on
# Таймаут одного HTTP-запроса, секунды.
# TITLE_FETCH_TIMEOUT_SECONDS=5
# Cap на тело ответа (и сжатое, и распакованное), байты.
# TITLE_FETCH_MAX_BYTES=262144
# Потолок редиректов (каждый hop проходит SSRF-проверку заново).
# TITLE_FETCH_MAX_REDIRECTS=3
# Максимальная длина сохранённого title, символы.
# TITLE_MAX_LENGTH=200
# Бюджет попыток: после стольких сбоев строка становится failed навсегда.
# TITLE_FETCH_MAX_ATTEMPTS=5
# Линейный бэкофф между попытками: attempt_count × столько секунд.
# TITLE_FETCH_RETRY_BACKOFF_SECONDS=60

# --- OpenRouter (classification / memory reasoning) -------------------------
# The only place the OpenRouter key is stored; read from here, never hardcoded
# or logged.
OPEN_ROUTER_AI_KEY=

# --- Voice storage ----------------------------------------------------------
# Local default is .data/voice. On the server, point it inside the ./data
# volume so audio persists across redeploys:
VOICE_STORAGE_ROOT=.data/voice
# Server default:
# VOICE_STORAGE_ROOT=/app/data/voice

# --- Image storage (S2: фото) ------------------------------------------------
# Оригиналы фото (immutable, {space}/{capture}/original.<ext>). Локальный
# дефолт .data/images; на сервере — внутрь ./data-тома, как у голоса:
# IMAGE_STORAGE_ROOT=.data/images
# IMAGE_STORAGE_ROOT=/app/data/images
# Потолок размера скачиваемого фото, байты (больше → мягкий отказ шага).
# IMAGE_MAX_FILE_SIZE_BYTES=10485760

# Optional: override the Whisper model. Voice transcription now works on Linux
# too (faster-whisper is cross-platform). Default is "small"; the first
# transcription downloads and caches the model weights once.
# WHISPER_MODEL=small

# --- HuggingFace / sentence-transformers weight cache -----------------------
# Not read by settings.py, but read by the libraries. On the server these point
# into the ./data volume so E5 weights download once and persist:
# HF_HOME=/app/data/hf-cache
# SENTENCE_TRANSFORMERS_HOME=/app/data/hf-cache
